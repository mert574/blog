---
import Base from '../layouts/Base.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE, SOCIALS, PROJECTS } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---
<Base>
  <section class="intro wrap">
    <p class="kicker">Senior software engineer</p>
    <h1>Hi, I'm Mert.</h1>
    <p class="lede">
      Close to a decade building for the web. I'm strongest in the frontend
      (React, Vue, TypeScript, Node), and lately I've been doing more backend and
      real-time systems. I built a PSP emulator down to its MIPS core for fun.
    </p>
    <p class="intro-more">
      Recently I built a low-latency WebRTC calling service using LiveKit. I run
      a small cluster at home that hosts my own tools and this site. I build a
      lot with Claude these days and genuinely enjoy it.
    </p>
    <div class="links">
      {SOCIALS.map((s) => <a href={s.href}>{s.label}</a>)}
    </div>
  </section>

  <section class="wrap block">
    <h2>Things I've built</h2>
    <ul class="projects">
      {
        PROJECTS.map((p) => (
          <li>
            <a class="proj-name" href={p.href}>{p.name}</a>
            <span class="kicker proj-tag">{p.tag}</span>
            <p>{p.blurb}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="wrap block">
    <div class="block-head">
      <h2>Recent writing</h2>
      <a class="kicker" href="/blog">all posts →</a>
    </div>
    <ul class="recent">
      {
        posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <span class="kicker"><FormattedDate date={post.data.date} /></span>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  .intro { padding-top: var(--gap); }
  .lede {
    font-size: 1.3rem;
    color: var(--ink);
    max-width: 54ch;
  }
  .intro-more {
    color: var(--muted);
    max-width: 58ch;
  }
  .links {
    display: flex;
    gap: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  .block { margin-top: var(--gap); }
  .block-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }

  .projects { list-style: none; padding: 0; }
  .projects li {
    padding: 1.2rem 0;
    border-top: 1px solid var(--rule);
  }
  .proj-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 560;
    color: var(--ink);
    text-decoration: none;
    margin-right: 0.6rem;
  }
  .proj-name:hover { background: none; color: var(--accent); }
  .proj-tag { color: var(--accent); }
  .projects p { margin: 0.4rem 0 0; color: var(--muted); }

  .recent { list-style: none; padding: 0; }
  .recent li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.7rem 0;
    border-top: 1px solid var(--rule);
  }
  .recent li a {
    font-size: 1.1rem;
    color: var(--ink);
    text-decoration: none;
  }
  .recent li a:hover { background: none; color: var(--accent); }
</style>
