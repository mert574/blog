---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SOCIALS, PROJECTS, HISTORY, isExternal } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
const iso = (d: Date) => d.toISOString().slice(0, 10);
const pad = (n: number) => String(n).padStart(2, '0');
const ext = (href: string) =>
  isExternal(href) ? { target: '_blank', rel: 'noopener' } : {};
---
<Base>
  <section class="intro wrap">
    <p class="cmd"><span class="prompt">$</span> whoami</p>
    <h1>Mert Yıldız<span class="cursor"></span></h1>
    <p class="role kicker">software engineer · berlin</p>
    <p>
      A decade building for the web. Most of that in the frontend, and these
      days more backend work on distributed systems.
    </p>
    <p>
      For fun, I built a
      <a class="ul" href="https://mert.js.org/psp-js/docs/" target="_blank" rel="noopener">PSP emulator</a>
      that runs real games. Lately I've been building
      <a class="ul" href="https://pulsepager.com" target="_blank" rel="noopener">Pulse Pager</a>,
      a full uptime monitoring service that doubles as my cloud and Kubernetes
      playground.
    </p>
    <p>
      Day to day I write TypeScript (React, Vue, Node), some Kotlin at work and Go
      on the side, and build a lot with Claude.
    </p>
    <div class="links">
      {
        SOCIALS.map((s) =>
          s.href.startsWith('mailto') ? (
            <a class="ul" id="copy-email" href={s.href}><span class="txt">{s.label}</span></a>
          ) : (
            <a class="ul" href={s.href} {...ext(s.href)}>{s.label}</a>
          ),
        )
      }
    </div>
  </section>

  <section class="wrap block">
    <p class="cmd"><span class="prompt">$</span> tail ~/latest-posts</p>
    <ul class="rows">
      {
        posts.map((post, i) => (
          <li class="row">
            <a class="rowlink post" href={`/blog/${post.id}`}>
              <span class="idx">{pad(i + 1)}</span>
              <span class="nm">{post.data.title}<span class="arw">→</span></span>
              <span class="dt">{iso(post.data.date)}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="more"><a class="ul" href="/blog">all posts →</a></p>
  </section>

  <section class="wrap block">
    <p class="cmd"><span class="prompt">$</span> cat ~/history</p>
    <ul class="rows">
      {
        HISTORY.map((h) => (
          <li class="row">
            <div class="rowlink hist">
              <span class="idx yrs">{h.years}</span>
              <span class="de"><span class="nm">{h.name}</span> {h.blurb}</span>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="wrap block">
    <p class="cmd"><span class="prompt">$</span> ls ~/open-source</p>
    <ul class="rows">
      {
        PROJECTS.map((p, i) => (
          <li class="row">
            <a class="rowlink proj" href={p.href} {...ext(p.href)}>
              <span class="idx">{pad(i + 1)}</span>
              <span class="de"><span class="nm">{p.name}</span> {p.blurb.join(' ')}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<script is:inline>
  // click-to-copy email with a brief confirm
  const c = document.getElementById('copy-email');
  if (c && navigator.clipboard) {
    c.addEventListener('click', (e) => {
      e.preventDefault();
      navigator.clipboard.writeText('hi@mert574.dev');
      const t = c.querySelector('.txt');
      const o = t.textContent;
      t.textContent = 'copied ✓';
      setTimeout(() => (t.textContent = o), 1400);
    });
  }
</script>

<style>
  .intro { padding-top: var(--gap); }
  .role { margin: 0.4rem 0 1.5rem; }
  h1 { font-size: clamp(2rem, 5vw, 2.8rem); }
  .links { display: flex; gap: 1.7rem; margin-top: 1.6rem; flex-wrap: wrap; font-size: 13px; }
  .block { margin-top: var(--gap); }
  .more { margin-top: 1rem; font-size: 13px; }

  .rows { list-style: none; padding: 0; margin: 0.7rem 0 0; }
  .row { border-bottom: 1px solid var(--rule); }
  .rowlink {
    display: grid;
    grid-template-columns: 2.6ch 1fr auto;
    gap: 0.15rem 1.2rem;
    align-items: baseline;
    padding: 1.2rem 0.5rem;
    position: relative;
    color: var(--text);
  }
  .rowlink:hover { text-decoration: none; background: var(--panel); }
  .rowlink::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--accent); transform: scaleY(0); transform-origin: top;
    transition: transform 0.3s var(--ease);
  }
  .rowlink:hover::before { transform: scaleY(1); }
  /* history rows: wider year column, and no link affordances (nothing to click) */
  /* timeline: a hairline through the rows, one dot per year, green for now */
  .row:has(.hist) { border-bottom: none; position: relative; }
  .row:has(.hist)::before {
    content: ''; position: absolute; left: 3px; top: 0; bottom: 0;
    width: 1px; background: var(--rule);
  }
  /* dot center = row padding (0.55rem) + half the 14px/1.75 first line box */
  .row:has(.hist):first-of-type::before { top: 21px; }
  .row:has(.hist):last-of-type::before { bottom: auto; height: 21px; }
  .row:has(.hist)::after {
    content: ''; position: absolute; left: 0; top: 17.5px;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--dim);
  }
  .row:has(.hist):first-of-type::after { background: var(--green); }
  .hist { grid-template-columns: 4.5ch 1fr; padding: 0.55rem 0.5rem 0.55rem 1.3rem; }
  .hist .de { max-width: none; margin-top: 0; grid-column: 2; }
  .hist .nm { color: var(--text); }
  .hist:hover { background: none; }
  .hist:hover::before { transform: scaleY(0); }
  .yrs { white-space: nowrap; }

  .idx, .dt, .yrs { font-family: var(--font-mono); }
  .idx { color: var(--dim); font-size: 12.5px; }
  .rowlink:hover .idx { color: var(--accent); }
  .nm { font-weight: 700; }
  .nm .arw {
    display: inline-block; opacity: 0; margin-left: 0.5ch; color: var(--accent);
    transform: translateX(-4px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .rowlink:hover .arw { opacity: 1; transform: translateX(0); }
  .de { grid-column: 2 / -1; color: var(--dim); margin-top: 0.4rem; font-size: 14px; }

  /* posts share the compact layout: no borders, tight rows */
  .row:has(.post) { border-bottom: none; }
  .post { padding: 0.55rem 0.5rem; }

  /* project rows share the compact history layout: no borders, inline name + blurb */
  .row:has(.proj) { border-bottom: none; }
  .proj { grid-template-columns: 2.6ch 1fr; padding: 0.55rem 0.5rem; }
  .proj .de { grid-column: 2; margin-top: 0; }
  .proj .nm { color: var(--text); }
  .dt { color: var(--dim); font-size: 12.5px; justify-self: end; }

  @media (max-width: 560px) {
    .rowlink { grid-template-columns: 2.6ch 1fr; column-gap: 0.9rem; }
    .dt { grid-column: 2; justify-self: start; margin-top: 0.25rem; }
    .de { grid-column: 2; }
    /* give descriptions the room back on small screens */
    .hist { padding-left: 1.1rem; }
    .rowlink, .proj { padding-right: 0; }
  }
</style>
