---
import '@fontsource-variable/newsreader';
import '@fontsource-variable/newsreader/wght-italic.css';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, updated, tags, cover, coverAlt } = post.data;
---
<Base title={title} description={description} image={cover?.src}>
  <article class="wrap post">
    <header>
      <p class="cmd"><span class="prompt">$</span> cat {post.id}.md</p>
      <p class="kicker meta">
        <FormattedDate date={date} />
        {updated && <span>· updated <FormattedDate date={updated} /></span>}
      </p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      {
        tags.length > 0 && (
          <p class="tags">
            {tags.map((t) => (
              <a class="kicker tag" href={`/tags/${t}`}>#{t}</a>
            ))}
          </p>
        )
      }
    </header>

    {
      cover && (
        <figure class="cover">
          <Image src={cover} alt={coverAlt ?? title} widths={[480, 800, 1200]} />
        </figure>
      )
    }

    <div class="prose" data-pagefind-body>
      <Content />
    </div>

    <p class="back"><a href="/blog">← all writing</a></p>
  </article>
</Base>

<style>
  /* Post title and section headings read in the prose serif, not the mono. */
  .post h1,
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: 'Newsreader Variable', Georgia, serif;
    word-spacing: normal;
    letter-spacing: 0;
  }
  .meta { display: flex; gap: 0.4rem; }
  .lede { font-size: 1.1rem; color: var(--dim); margin-top: 0.4rem; }
  .tags { display: flex; gap: 0.9rem; flex-wrap: wrap; }
  .tag { color: var(--accent); text-decoration: none; }
  .cover { margin: var(--gap) 0; }
  /* Prose reads in a serif; the terminal chrome (headings, code, meta) stays mono. */
  .prose {
    font-family: 'Newsreader Variable', Georgia, serif;
    font-size: 1.2rem;
    line-height: 1.55;
    max-width: 62ch;
  }
  .prose :global(h2) { margin-top: 2.4rem; }
  /* Space the whole Expressive Code frame; let EC style its own <pre> (touching
     the inner pre adds a gap between the window bar and the code). */
  .prose :global(.expressive-code) { margin: 1.4rem 0; }
  .back { margin-top: var(--gap); font-family: var(--font-mono); font-size: 0.85rem; }
</style>
