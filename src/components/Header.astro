---
import { Icon } from 'astro-icon/components';
import { NAV } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-head wide">
  <a class="brand" href="/"><span class="prompt">mert574</span><span class="tilde"> ~ %</span></a>
  <nav aria-label="Primary">
    {
      NAV.map((item) => (
        <a href={item.href} class:list={['nav-link ul', { active: isActive(item.href) }]}>
          {item.label.toLowerCase()}
        </a>
      ))
    }
    <button id="theme-toggle" class="nav-link" type="button" aria-label="Toggle color scheme">
      <span class="when-dark"><Icon name="lucide:sun" /></span>
      <span class="when-light"><Icon name="lucide:moon" /></span>
    </button>
  </nav>
</header>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', () => {
    const de = document.documentElement;
    const next = de.dataset.theme === 'light' ? 'dark' : 'light';
    de.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>

<style>
  .site-head {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.3rem 0;
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
  }
  .brand { font-weight: 700; color: var(--text); text-decoration: none; margin-right: auto; }
  .brand:hover { text-decoration: none; }
  .tilde { color: var(--dim); }
  nav { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  /* padding + negative margin: bigger touch targets without shifting the layout */
  .nav-link { color: var(--dim); font-size: 13px; padding: 0.5rem 0.25rem; margin: -0.5rem -0.25rem; }
  .nav-link:hover { color: var(--accent); }
  .nav-link.active { color: var(--text); }

  #theme-toggle {
    background: none; border: none; cursor: pointer;
    color: var(--dim); display: flex; align-items: center;
  }
  #theme-toggle:hover { color: var(--accent); }
  #theme-toggle svg { width: 15px; height: 15px; }
  /* show the theme you'd switch to */
  .when-light { display: none; }
  .when-dark { display: flex; }
  :global([data-theme='light']) .when-light { display: flex; }
  :global([data-theme='light']) .when-dark { display: none; }
</style>
