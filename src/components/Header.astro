---
import { NAV } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-head wide">
  <a class="brand" href="/"><span class="prompt">mert574</span><span class="tilde"> ~ %</span></a>
  <nav aria-label="Primary">
    {
      NAV.map((item) => (
        <a href={item.href} class:list={['nav-link ul', { active: isActive(item.href) }]}>
          {item.label.toLowerCase()}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .site-head {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.3rem 0;
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
  }
  .brand { font-weight: 700; color: var(--text); text-decoration: none; margin-right: auto; }
  .brand:hover { text-decoration: none; }
  .tilde { color: var(--dim); }
  nav { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .nav-link { color: var(--dim); font-size: 13px; }
  .nav-link:hover { color: var(--accent); }
  .nav-link.active { color: var(--text); }
</style>
