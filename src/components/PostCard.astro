---
import FormattedDate from './FormattedDate.astro';
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
}
const { href, title, description, date, tags } = Astro.props;
---
<article class="post-card">
  <a class="title" href={href}>{title}</a>
  <p class="kicker meta">
    <FormattedDate date={date} />
    {tags.length > 0 && <span>· {tags.join(' · ')}</span>}
  </p>
  <p class="desc">{description}</p>
</article>

<style>
  .post-card {
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 560;
    line-height: 1.15;
    color: var(--ink);
    text-decoration: none;
  }
  .title:hover { background: none; color: var(--accent); }
  .meta { margin: 0.5rem 0 0.4rem; display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .desc { margin: 0; color: var(--muted); }
</style>
