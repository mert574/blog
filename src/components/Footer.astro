---
import { SITE, SOCIALS, isExternal } from '../consts';
const year = new Date().getFullYear();
const ext = (href: string) =>
  isExternal(href) ? { target: '_blank', rel: 'noopener' } : {};
const elsewhere = [
  ...SOCIALS,
  { label: 'LeetCode', href: 'https://leetcode.com/u/mert574/' },
  { label: 'RSS', href: '/rss.xml' },
];
---
<footer class="site-foot">
  <div class="wide">
    <div class="foot-grid">
      <div class="identity">
        <span class="wm">mert574<span class="tld">.dev</span></span>
        <p class="who">Software engineer · Berlin</p>
      </div>

      <nav class="elsewhere" aria-label="Elsewhere">
        {elsewhere.map((s) => <a class="ul" href={s.href} {...ext(s.href)}>{s.label}</a>)}
      </nav>
    </div>

    <div class="bar-inner">
      <span>© {year} {SITE.author}</span>
      <span>Served from my homelab</span>
    </div>
  </div>
</footer>

<style>
  .site-foot {
    margin-top: calc(var(--gap) * 2);
    background: var(--panel);
    border-top: 1px solid var(--rule);
  }

  .foot-grid {
    display: flex;
    justify-content: space-between;
    align-items: last baseline;
    gap: 1.6rem 4rem;
    flex-wrap: wrap;
    padding: clamp(1.6rem, 3vw, 2.2rem) 0 clamp(1.2rem, 2vw, 1.6rem);
  }

  .identity .wm {
    font-family: var(--font-mono);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .identity .tld { color: var(--accent); }
  .who {
    margin: 0.45rem 0 0;
    font-family: var(--font-mono);
    color: var(--dim);
    font-size: 12.5px;
    letter-spacing: 0.02em;
  }

  .elsewhere { display: flex; gap: 1.7rem; flex-wrap: wrap; align-items: baseline; }
  .elsewhere a { color: var(--dim); font-size: 13px; }
  .elsewhere a:hover { color: var(--accent); }

  .bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.6rem 1.6rem;
    flex-wrap: wrap;
    padding: 1rem 0 1.5rem;
    border-top: 1px solid var(--rule);
    color: var(--dim);
    font-size: 12.5px;
  }</style>
